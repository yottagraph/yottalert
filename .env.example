# Aether Application Configuration
# Copy this file to .env and fill in values for local development.
# For deployed environments, set these same variables in your platform (Vercel, etc.).

# App Identity (REQUIRED - Must be unique per app!)
NUXT_PUBLIC_APP_ID=
NUXT_PUBLIC_APP_NAME=

# Query Server
NUXT_PUBLIC_QUERY_SERVER_ADDRESS=

# Auth0 (required for login)
# See README "Environment variables" for details.
NUXT_PUBLIC_AUTH0_ISSUER_BASE_URL=https://auth.lovelace.ai
NUXT_PUBLIC_AUTH0_CLIENT_ID=
NUXT_PUBLIC_AUTH0_CLIENT_SECRET=
NUXT_PUBLIC_AUTH0_AUDIENCE=queryserver:api
NUXT_PUBLIC_COOKIE_SECRET=

# Leave empty when using Auth0 (otherwise auth is bypassed)
NUXT_PUBLIC_USER_NAME=

# --- Storage ---
# Auto-populated for deployed builds on Vercel.
# For local dev, these are fetched from the portal during init.
# If missing, get them from your Vercel project settings → Environment Variables.

# Firestore (Aether prefs — BC 2.0 default; ENG-520) ----------------
# Provisioned per-tenant by the Broadchurch portal. Set on Vercel for
# deployed tenants automatically. For local dev, leave these blank —
# `.aether-dev-prefs/` under the project root handles persistence
# across `npm run dev` page refreshes without any cloud credentials.
# NUXT_PUBLIC_FIRESTORE_ENABLED=true
# NUXT_PUBLIC_FIRESTORE_PROJECT_ID=
# NUXT_PUBLIC_FIRESTORE_DATABASE_ID=(default)
# NUXT_PUBLIC_FIRESTORE_LOCATION=us-central1
# Server-only — base64-encoded service-account JSON key. Never expose
# this to the client bundle.
# NUXT_FIRESTORE_SA_KEY=

# KV Store (Upstash Redis) — legacy BC 1.0 prefs backend, kept for
# tenants provisioned before ENG-520. New BC 2.0 tenants don't get a KV
# store and use the Firestore variables above instead.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Neon Postgres — leave commented out. DATABASE_URL is auto-injected by Vercel
# on deploy; there is no local Neon setup. Check provisioning via the portal,
# using the values from broadchurch.yaml (gateway.url and tenant.org_id):
# curl <gateway.url>/api/tenants/<tenant.org_id> → look for vercel.postgres_store_id
# DATABASE_URL=
# DATABASE_URL_UNPOOLED=
