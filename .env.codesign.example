# Apple Developer Code Signing & Notarization Configuration
# Copy this to .env.codesign and fill in your values

# Certificate name (already configured)
export CSC_NAME="Lovelace AI, Inc. (QBGD4496C3)"

# REQUIRED for notarization - Team ID
export APPLE_TEAM_ID="QBGD4496C3"

# REQUIRED for notarization - Your Apple ID
export APPLE_ID="your-email@lovelace.ai"

# REQUIRED for notarization - App-specific password
# Generate at: https://appleid.apple.com/account/manage
export APPLE_APP_SPECIFIC_PASSWORD="xxxx-xxxx-xxxx-xxxx"
